# Supabase Configuration Example
# Copy this file to .env and fill in your Supabase credentials

# Logging
Logging__LogLevel__Default=Information
Logging__LogLevel__Microsoft.AspNetCore=Warning

# Database Provider - Set to Supabase
DatabaseProvider=Supabase

# Supabase Connection String
# Get these values from: Supabase Dashboard → Settings → Database
ConnectionStrings__Supabase=Host=db.yourproject.supabase.co;Port=5432;Database=postgres;Username=postgres;Password=YOUR_SUPABASE_PASSWORD;SslMode=Require;

# Optional: Connection Pooler (Recommended for Production)
# Use port 6543 for connection pooling
# ConnectionStrings__Supabase=Host=db.yourproject.supabase.co;Port=6543;Database=postgres;Username=postgres.yourproject;Password=YOUR_SUPABASE_PASSWORD;Pooling=true;Maximum Pool Size=10;SslMode=Require;

# App Settings
AppSettings__Token="aVeryLockAndSecureSuperDuperLongToken"

# CORS Origins (Update with your frontend URLs)
AllowedOrigins__0=https://your-frontend-app.vercel.app
AllowedOrigins__1=http://localhost:5173
AllowedOrigins__2=https://localhost:5173

# Instructions:
# 1. Replace 'yourproject' with your actual Supabase project reference
# 2. Replace 'YOUR_SUPABASE_PASSWORD' with your database password
# 3. Update AllowedOrigins with your actual frontend URLs
# 4. Generate a new secure token for AppSettings__Token
# 5. Save this file as .env (without .supabase.example)
# 6. Never commit .env to version control!
